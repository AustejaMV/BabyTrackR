# ─── Supabase (REQUIRED) ────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── RevenueCat (purchases) ──────────────────────────────────
# Get from: https://app.revenuecat.com → Project → API Keys
# Native (app-specific API keys):
# VITE_RC_IOS_KEY=appl_your_ios_api_key
# VITE_RC_ANDROID_KEY=goog_your_android_api_key
# Web Billing (from Apps & providers → Web Billing config → Public API Key):
# VITE_RC_WEB_KEY=rcb_your_web_public_api_key

# ─── Optional overrides ────────────────────────────────────
# Override Edge Function URL (for local Supabase dev)
# VITE_SERVER_URL=http://localhost:54321/functions/v1/server
