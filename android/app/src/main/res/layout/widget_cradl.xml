<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Cradl"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cradl"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#2c1f1f"
            android:fontFamily="serif" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_feed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🍼 No feeds yet"
        android:textSize="12sp"
        android:textColor="#5a4a4a"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/widget_sleep"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="😴 No sleeps yet"
        android:textSize="12sp"
        android:textColor="#5a4a4a"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/widget_nappy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🧷 No nappies yet"
        android:textSize="12sp"
        android:textColor="#5a4a4a"
        android:layout_marginTop="2dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center">

        <Button
            android:id="@+id/btn_feed"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Feed"
            android:textSize="11sp"
            android:textColor="#ffffff"
            android:backgroundTint="#d4604a"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btn_sleep"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Sleep"
            android:textSize="11sp"
            android:textColor="#ffffff"
            android:backgroundTint="#4a7ab4"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btn_nappy"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Nappy"
            android:textSize="11sp"
            android:textColor="#ffffff"
            android:backgroundTint="#4a8a4a" />
    </LinearLayout>
</LinearLayout>
